          <mxGeometry x="700" y="600" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- PRIMARY FLOW EDGES (blue, bold) -->

        <!-- User to Application Gateway -->
        <mxCell id="e1" value="HTTPS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#0078D4;fontColor=#0078D4;fontSize=10;labelBackgroundColor=#FFFFFF;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="user" target="gateway">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Gateway to App Service -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#0078D4;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="gateway" target="webapp">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="775" y="210"/>
              <mxPoint x="405" y="210"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- App Service to API Management -->
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#0078D4;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="webapp" target="apim">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- API Management to Functions -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#0078D4;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="apim" target="functions">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DATA CONNECTION EDGES (gray) -->

        <!-- App Service to Azure Maps -->
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#757575;exitX=0;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="webapp" target="maps">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="380" y="374"/>
              <mxPoint x="345" y="374"/>
            </Array>
          </mxGeometry>
