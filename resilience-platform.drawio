        <!-- Functions to MySQL -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#757575;exitX=0;exitY=1;entryX=0.75;entryY=0;" edge="1" parent="1" source="functions" target="mysql">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1020" y="390"/>
              <mxPoint x="618" y="390"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Functions to Blob Storage -->
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#757575;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="functions" target="blob">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1045" y="394"/>
              <mxPoint x="875" y="394"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Functions to Key Vault -->
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#757575;exitX=1;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="functions" target="keyvault">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1070" y="398"/>
              <mxPoint x="1135" y="398"/>
            </Array>
