        <!-- MONITORING EDGES (orange dashed) -->

        <!-- Monitor to App Service -->
        <mxCell id="e12" value="telemetry" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#E65100;dashed=1;dashPattern=8 4;fontColor=#E65100;fontSize=9;labelBackgroundColor=#FFFFFF;exitX=0.25;exitY=0;entryX=0.25;entryY=1;" edge="1" parent="1" source="monitor" target="webapp">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="713" y="555"/>
              <mxPoint x="393" y="555"/>
            </Array>
