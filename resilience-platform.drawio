        <!-- App Service to MySQL -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=1.5;strokeColor=#757575;exitX=0.5;exitY=1;entryX=0.25;entryY=0;" edge="1" parent="1" source="webapp" target="mysql">
