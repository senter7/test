<mxfile host="app.diagrams.net">
  <diagram id="ResiliencePlatform" name="Resilience Platform">
    <mxGraphModel dx="1420" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Resilience Platform" style="text;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1a1a1a;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="520" y="5" width="360" height="35" as="geometry"/>
        </mxCell>

        <!-- Azure Cloud Boundary -->
        <mxCell id="cloud" value="" style="rounded=1;whiteSpace=wrap;arcSize=3;fillColor=none;strokeColor=#0078D4;strokeWidth=2;dashed=1;dashPattern=8 4;" vertex="1" parent="1">
          <mxGeometry x="210" y="50" width="1130" height="670" as="geometry"/>
        </mxCell>
        <mxCell id="cloudLabel" value="Microsoft Azure" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#FFFFFF;fillColor=#0078D4;rounded=1;arcSize=50;spacingLeft=12;spacingRight=12;" vertex="1" parent="1">
          <mxGeometry x="225" y="35" width="150" height="28" as="geometry"/>
        </mxCell>

        <!-- Tier 1 Background: Ingress -->
        <mxCell id="t1bg" value="" style="rounded=1;whiteSpace=wrap;arcSize=6;fillColor=#E8F4FD;strokeColor=#B3D9F2;strokeWidth=1;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="230" y="70" width="1090" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="t1label" value="INGRESS" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fontStyle=1;fontColor=#0078D4;fillColor=none;strokeColor=none;spacingLeft=6;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="232" y="72" width="70" height="16" as="geometry"/>
        </mxCell>

        <!-- Tier 2 Background: Compute -->
        <mxCell id="t2bg" value="" style="rounded=1;whiteSpace=wrap;arcSize=6;fillColor=#E8F8E8;strokeColor=#B3E0B3;strokeWidth=1;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="230" y="230" width="1090" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="t2label" value="COMPUTE" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fontStyle=1;fontColor=#2E7D32;fillColor=none;strokeColor=none;spacingLeft=6;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="232" y="232" width="70" height="16" as="geometry"/>
        </mxCell>

        <!-- Tier 3 Background: Data and Services -->
        <mxCell id="t3bg" value="" style="rounded=1;whiteSpace=wrap;arcSize=6;fillColor=#FFF3E0;strokeColor=#FFCC80;strokeWidth=1;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="230" y="400" width="1090" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="t3label" value="DATA &amp; SERVICES" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fontStyle=1;fontColor=#E65100;fillColor=none;strokeColor=none;spacingLeft=6;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="232" y="402" width="110" height="16" as="geometry"/>
        </mxCell>

        <!-- Tier 4 Background: Management and Security -->
        <mxCell id="t4bg" value="" style="rounded=1;whiteSpace=wrap;arcSize=6;fillColor=#F3E5F5;strokeColor=#CE93D8;strokeWidth=1;opacity=50;" vertex="1" parent="1">
          <mxGeometry x="230" y="570" width="1090" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="t4label" value="MANAGEMENT &amp; SECURITY" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fontStyle=1;fontColor=#6A1B9A;fillColor=none;strokeColor=none;spacingLeft=6;spacingTop=2;" vertex="1" parent="1">
          <mxGeometry x="232" y="572" width="170" height="16" as="geometry"/>
        </mxCell>

        <!-- User -->
        <mxCell id="user" value="User" style="shape=mxgraph.azure2.identity.Users;aspect=fixed;whiteSpace=wrap;html=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=12;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="60" y="95" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- Tier 1: Application Gateway -->
        <mxCell id="gateway" value="Application&#xa;Gateway" style="shape=mxgraph.azure2.networking.Application_Gateways;aspect=fixed;whiteSpace=wrap;html=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="750" y="95" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- Tier 2: App Service -->
        <mxCell id="webapp" value="App Service&#xa;(Web App)" style="shape=mxgraph.azure2.app_services.App_Services;aspect=fixed;whiteSpace=wrap;html=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="380" y="260" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- Tier 2: API Management -->
        <mxCell id="apim" value="API&#xa;Management" style="shape=mxgraph.azure2.integration.API_Management_Services;aspect=fixed;whiteSpace=wrap;html=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="700" y="260" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- Tier 2: Azure Functions -->
        <mxCell id="functions" value="Azure Functions&#xa;(Calculation)" style="shape=mxgraph.azure2.compute.Function_Apps;aspect=fixed;whiteSpace=wrap;html=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1020" y="260" width="50" height="50" as="geometry"/>
