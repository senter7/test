          <mxGeometry x="580" y="430" width="50" height="50" as="geometry"/>
        </mxCell>

        <!-- Tier 3: Blob Storage -->
        <mxCell id="blob" value="Blob&#xa;Storage" style="shape=mxgraph.azure2.storage.Blob_Block;aspect=fixed;whiteSpace=wrap;html=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;fontSize=11;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="850" y="430" width="50" height="50" as="geometry"/>
